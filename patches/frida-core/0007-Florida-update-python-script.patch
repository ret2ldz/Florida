From: Ylarod <me@ylarod.cn>
Date: Tue, 18 Jul 2023 19:55:59 +0800
Subject: [PATCH 7/9] Florida: update python script

Refactors `src/anti-anti-frida.py` with colored logging, extends the
symbol rename charset to mixed case, adds rodata reversal of 4 internal
Frida/GLib string fingerprints (`FridaScriptEngine`, `GLib-GIO`,
`GDBusProxy`, `GumScript`), and adds the `gdbus` thread name patch
(5-char random).

Re-generated against current frida main. The original 0007 patch had a
typo in its `old` context — it expected `print(f"[-] Patch \`gmain\`...")`
(dash) but the actual line left by 0005 was `print(f"[*] Patch \`gmain\`...")`
(asterisk). That typo caused the patch to fail `git apply`. Now fixed —
context matches the real post-0005 state.

---
 src/anti-anti-frida.py | 35 +++++++++++++++++++----------------
 1 file changed, 23 insertions(+), 12 deletions(-)

diff --git a/src/anti-anti-frida.py b/src/anti-anti-frida.py
index 83e8d3e..6dc1c66 100644
--- a/src/anti-anti-frida.py
+++ b/src/anti-anti-frida.py
@@ -3,35 +3,59 @@ import sys
 import random
 import os
 
+def log_color(msg):
+    print(f"\033[1;31;40m{msg}\033[0m")
+
 if __name__ == "__main__":
     input_file = sys.argv[1]
-    print(f"[*] Patch frida-agent: {input_file}")
-    random_name = "".join(random.sample("ABCDEFGHIJKLMNO", 5))
-    print(f"[*] Patch `frida` to `{random_name}```")
-
+    random_charset = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz"
+    log_color(f"[*] Patch frida-agent: {input_file}")
     binary = lief.parse(input_file)
 
     if not binary:
+        log_color(f"[*] Not elf, exit")
         exit()
 
+    random_name = "".join(random.sample(random_charset, 5))
+    log_color(f"[*] Patch `frida` to `{random_name}`")
+
     for symbol in binary.symbols:
         if symbol.name == "frida_agent_main":
             symbol.name = "main"
-        
+
         if "frida" in symbol.name:
             symbol.name = symbol.name.replace("frida", random_name)
 
         if "FRIDA" in symbol.name:
             symbol.name = symbol.name.replace("FRIDA", random_name)
 
+    all_patch_string = ["FridaScriptEngine", "GLib-GIO", "GDBusProxy", "GumScript"]
+    for section in binary.sections:
+        if section.name != ".rodata":
+            continue
+        for patch_str in all_patch_string:
+            addr_all = section.search_all(patch_str)
+            for addr in addr_all:
+                patch = [ord(n) for n in list(patch_str)[::-1]]
+                reversed_patch_str = ''.join(list(patch_str)[::-1])
+                log_color(f"[*] Patching section name={section.name} offset={hex(section.file_offset + addr)} orig:{patch_str} new:{reversed_patch_str}")
+                binary.patch_address(section.file_offset + addr, patch)
+
     binary.write(input_file)
 
-    # gum-js-loop thread
-    random_name = "".join(random.sample("abcdefghijklmn", 11))
-    print(f"[*] Patch `gum-js-loop` to `{random_name}`")
