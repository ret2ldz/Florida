From e108bdb7be0e5756a613fbe1162f07a8623da327 Mon Sep 17 00:00:00 2001
From: Ylarod <me@ylarod.cn>
Date: Tue, 18 Jul 2023 16:02:50 +0800
Subject: [PATCH 3/9] Florida: symbol_frida_agent_main

Renames the entry-point symbol from `frida_agent_main` to `main` across
all host-session files (so dlsym scans for `frida_agent_main` no longer
match), and creates `src/anti-anti-frida.py` to rename leftover
`frida`/`FRIDA` substrings in the compiled ELF symbols post-build.

Re-generated against current frida main. Line numbers shifted because
host-session files were refactored (e.g. `windows-host-session.vala` got
an `#else` branch with a second `frida_agent_main` reference that the
original patch missed — now both branches are renamed). Logic is
unchanged: same 8 files modified, same new file created.

---
 src/agent-container.vala              | 2 +-
 src/anti-anti-frida.py                | 27 +++++++++++++++++++++++++++
 src/darwin/darwin-host-session.vala   | 2 +-
 src/freebsd/freebsd-host-session.vala | 2 +-
 src/linux/linux-host-session.vala     | 2 +-
 src/qnx/qnx-host-session.vala         | 2 +-
 src/windows/windows-host-session.vala | 4 ++--
 tests/test-agent.vala                 | 2 +-
 tests/test-injector.vala              | 2 +-
 9 files changed, 35 insertions(+), 9 deletions(-)
 create mode 100644 src/anti-anti-frida.py

diff --git a/src/agent-container.vala b/src/agent-container.vala
index eecfa1f..86eb9f4 100644
--- a/src/agent-container.vala
+++ b/src/agent-container.vala
@@ -28,7 +28,7 @@ namespace Frida {
 			}
 
 			void * main_func_symbol;
-			var main_func_found = container.module.symbol ("frida_agent_main", out main_func_symbol);
+			var main_func_found = container.module.symbol ("main", out main_func_symbol);
 			assert (main_func_found);
 			container.main_impl = (AgentMainFunc) main_func_symbol;
 
diff --git a/src/anti-anti-frida.py b/src/anti-anti-frida.py
new file mode 100644
index 0000000..ade2543
--- /dev/null
+++ b/src/anti-anti-frida.py
@@ -0,0 +1,27 @@
+import lief
+import sys
+import random
+import os
+
+if __name__ == "__main__":
+    input_file = sys.argv[1]
+    print(f"[*] Patch frida-agent: {input_file}")
+    random_name = "".join(random.sample("ABCDEFGHIJKLMNO", 5))
+    print(f"[*] Patch `frida` to `{random_name}```")
+
+    binary = lief.parse(input_file)
+
+    if not binary:
+        exit()
+
+    for symbol in binary.symbols:
+        if symbol.name == "frida_agent_main":
+            symbol.name = "main"
+        
+        if "frida" in symbol.name:
+            symbol.name = symbol.name.replace("frida", random_name)
+
+        if "FRIDA" in symbol.name:
+            symbol.name = symbol.name.replace("FRIDA", random_name)
+
+    binary.write(input_file)
\ No newline at end of file
